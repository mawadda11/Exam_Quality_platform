APP_ENV=development
APP_NAME=AI Exam Quality Platform
API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-development-secret
DATABASE_URL=postgresql+psycopg://exam_quality:exam_quality@postgres:5432/exam_quality
CHROMA_HOST=chromadb
CHROMA_PORT=8000
UPLOAD_ROOT=/app/storage/uploads
EXTRACTED_ROOT=/app/storage/extracted
REPORT_ROOT=/app/storage/reports
MAX_UPLOAD_MB=50
ALLOWED_ORIGINS=http://localhost:5173
AI_PROVIDER=stub
AI_MODEL=not-configured
AI_API_KEY=
OCR_PROVIDER=stub
OCR_API_KEY=
FILE_RETENTION_DAYS=30
LOG_LEVEL=INFO
