APP_ENV=development
APP_NAME=AI Exam Quality Platform
API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-development-secret
# For running the backend natively (cd backend && ...): Postgres reachable
# at localhost, e.g. via `docker compose up -d postgres` (published on
# 5432) or a native PostgreSQL install with a matching role/database.
# docker-compose.yml overrides this to the "postgres" Compose hostname for
# its own backend container - do not change this line to "postgres".
DATABASE_URL=postgresql+psycopg://exam_quality:exam_quality@localhost:5432/exam_quality
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Relative to backend/ (the app's cwd for native runs); docker-compose.yml
# overrides these to the container's absolute /app/... mount paths.
UPLOAD_ROOT=../storage/uploads
EXTRACTED_ROOT=../storage/extracted
REPORT_ROOT=../storage/reports
KB_SOURCE_DIR=../knowledge_base/source
MAX_UPLOAD_MB=50
ALLOWED_ORIGINS=http://localhost:5173
AI_PROVIDER=stub
AI_MODEL=not-configured
AI_API_KEY=
# OCR has no env vars of its own: it runs locally via Tesseract (never a
# cloud vendor, so exam content never leaves the server - see
# docs/SECURITY_AND_PRIVACY.md's external-provider rule) and needs no API
# key or provider selection. Native (non-Docker) runs need the tesseract-ocr
# system package installed separately; docker-compose's backend image
# already includes it (see backend/Dockerfile).
FILE_RETENTION_DAYS=30
LOG_LEVEL=INFO
